generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String        @id @default(uuid())
  email             String        @unique
  name              String
  pfpUrl            String
  ownedInstitutions Institution[] @relation("owned")
  collaborator      Institution[] @relation("InstitutionToUser")
}

model Institution {
  id       String    @id @default(uuid())
  ownerId  String
  name     String
  slug     String
  plan     String
  owner    User      @relation("owned", fields: [ownerId], references: [id])
  projects Project[]
  members  User[]    @relation("InstitutionToUser")
}

model Project {
  id            String      @id @default(uuid())
  name          String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  db_name       String      @unique
  db_pwd        String
  db_user       String      @unique
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  sqlfolders    SqlFolder[]
  sqlqueries    sql[]
}

model SqlFolder {
  id        String  @id @default(uuid())
  projectId String
  name      String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  queries   sql[]
}

model SchemaEditorPosition {
  projectId String
  schema    String
  x         Int
  y         Int
  node_id   String @id
}

model sql {
  id        String     @id @default(uuid())
  projectId String
  folderId  String?
  createdAt DateTime   @default(now())
  name      String
  query     String
  folder    SqlFolder? @relation(fields: [folderId], references: [id])
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model sso_providers {
  name     String @id
  img_path String @unique
}
